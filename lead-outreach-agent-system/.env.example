POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=n8n

GENERIC_TIMEZONE=America/New_York

# Generate a real local value with:
# openssl rand -hex 32
# You can paste your generated key here after copying this file to .env.
N8N_ENCRYPTION_KEY=replace_with_generated_64_character_hex_key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password

# Keep false until the local workflow is fully tested.
SEND_EMAILS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
EMAIL_RATE_LIMIT_PER_HOUR=20

# Supabase logging/memory storage. Leave blank to use the local JSONL fallback.
# The same Supabase values are used by outreach-task-agent to create website tasks.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LOG_TABLE=outreach_logs

# Real company discovery/contact-provider keys. Do not commit real values.
# Google requires both a Custom Search JSON API key and a Programmable Search Engine ID.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Recommended web search provider for new setups.
TAVILY_API_KEY=

# Apollo requires a master API key for People API Search.
APOLLO_API_KEY=
APOLLO_REVEAL_PERSONAL_EMAILS=false

# Hunter can find public company-domain contacts on its free plan.
HUNTER_API_KEY=

# Keep false for production-like runs so missing provider keys fail loudly.
ALLOW_PLACEHOLDER_DATA=false

# Future API keys go here. Do not commit real values.
OPENAI_API_KEY=
HUNTER_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
